<Window x:Class="MolochnyKombinat.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя" Height="403" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Логин:" Margin="0,5"/>
        <TextBox Grid.Row="1" Name="txtLogin" Margin="0,0,0,10" Height="30"/>

        <TextBlock Grid.Row="2" Text="Пароль:" Margin="0,5"/>
        <PasswordBox Grid.Row="3" Name="txtPassword" Margin="0,0,0,10" Height="30"/>

        <TextBlock Grid.Row="4" Text="Роль:" Margin="0,5"/>
        <ComboBox Grid.Row="5" Name="cmbRole" Margin="0,0,0,10" Height="30">
            <ComboBoxItem Content="User"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>

        <CheckBox Grid.Row="6" Name="chkBlocked" Content="Заблокирован" Margin="0,10"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Name="btnSave" Content="Сохранить" Width="100" Height="35" Margin="10"
                    Background="#4CAF50" Foreground="White" Click="btnSave_Click"/>
            <Button Name="btnCancel" Content="Отмена" Width="100" Height="35" Margin="10"
                    Background="#F44336" Foreground="White" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>