<Window x:Class="MolochnyKombinat.Views.ValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Валидация данных клиента" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" MinWidth="500" MinHeight="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Валидация данных клиента" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Name="btnGetData" Content="Получить данные" Width="150" Height="40" Margin="10"
                    Background="#2196F3" Foreground="White" FontSize="14"
                    Click="btnGetData_Click"/>
            <Button Name="btnValidate" Content="Проверить" Width="150" Height="40" Margin="10"
                    Background="#FF9800" Foreground="White" FontSize="14"
                    IsEnabled="False" Click="btnValidate_Click"/>
            <Button Name="btnSendResult" Content="Отправить результат" Width="180" Height="40" Margin="10"
                    Background="#4CAF50" Foreground="White" FontSize="14"
                    IsEnabled="False" Click="btnSendResult_Click"/>
        </StackPanel>

        <!-- Полученные данные -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="ФИО клиента:" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Name="txtFullName" FontSize="14" Foreground="Blue" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Результат проверки -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Результат:" FontSize="14" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Name="txtValidationResult" FontSize="14" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Запрещенные символы:" FontSize="14" FontWeight="Bold" Margin="0,5,10,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Name="txtInvalidSymbols" FontSize="14" Foreground="Red" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Статус -->
        <TextBlock Grid.Row="4" Name="txtStatus" Text="" FontSize="12" 
                   Foreground="Gray" Margin="0,5"/>

        <Separator Grid.Row="5" Margin="0,15"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Name="btnSaveToWord" Content="Сохранить в ТестКейс" Width="150" Height="35" Margin="5"
                    Background="#9C27B0" Foreground="White" Click="btnSaveToWord_Click"/>
            <Button Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5"
                    Background="#F44336" Foreground="White" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>